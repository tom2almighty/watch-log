# Douban provider
# Sync requests are paginated with count <= 50.
NUXT_DOUBAN_API_KEY=
NUXT_DOUBAN_API_BASE=https://frodo.douban.com/api/v2
NUXT_DOUBAN_USER_ID=
NUXT_DOUBAN_USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 15_3 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Mobile/15E148 MicroMessenger/8.0.16(0x18001023) NetType/WIFI Language/zh_CN
NUXT_DOUBAN_REFERER=https://servicewechat.com/wx2f9b06c1de1ccfca/99/page-frame.html
NUXT_DOUBAN_ACCEPT_LANGUAGE=zh-CN,zh;q=0.9,en;q=0.8

# Admin security
# Required for calling /api/admin/* endpoints.
NUXT_ADMIN_TOKEN=

# Storage
NUXT_DB_PATH=./data/watchlog.sqlite

# Scheduled sync
NUXT_ENABLE_SYNC_CRON=false
NUXT_SYNC_CRON_EXPRESSION=0 */6 * * *

# Image proxy defaults
# direct: use source image URL
# prefix: https://image.example.com/search/down?url=
# relay: use the local /api/image relay endpoint
NUXT_IMAGE_PROXY_MODE=relay
NUXT_IMAGE_PROXY_PREFIX=

# Public app metadata
NUXT_PUBLIC_APP_NAME=watchlog
NUXT_PUBLIC_APP_TITLE=观迹
NUXT_PUBLIC_IMAGE_PROXY_MODE=relay
