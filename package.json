{
  "name": "watch-log",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm run build:widget && nuxt build",
    "dev": "pnpm run build:widget && nuxt dev",
    "generate": "pnpm run build:widget && nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:run": "vitest run",
    "verify": "pnpm vitest && pnpm build",
    "build:widget": "pnpm --filter ./packages/widget build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "better-sqlite3": "^12.6.2",
    "nuxt": "^4.3.1",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^18.0.1",
    "@vitejs/plugin-vue": "^6.0.1"
  }
}
